      "base_url": "https://wandb.internal",
      "api_key_secret": "default/wandb-api-key"
    },
    "mlflow": {
      "experiment_name": "llama-finetuning",
      "name": "run-001",
      "tracking_uri": "http://mlflow:5000",
      "tags": {
        "team": "nlp"
      },
      "description": "SFT experiment"
    }
  }
}
