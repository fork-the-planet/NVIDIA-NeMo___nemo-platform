{
  "model": "default/qwen3-1.7b",
  "dataset": {
    "training": "default/train-data"
  },
  "training": {
    "training_type": "sft",
    "finetuning_type": "lora",
    "max_seq_length": 2048
  },
  "schedule": {
    "epochs": 1,
    "max_steps": 10
  },
  "batch": {
    "global_batch_size": 8,
    "micro_batch_size": 1
  },
  "optimizer": {
    "learning_rate": 5e-6
  },
  "parallelism": {
    "num_nodes": 1,
    "num_gpus_per_node": 1,
    "tensor_parallel_size": 1
  },
  "output": {
    "name": "test-out"
  }
}
