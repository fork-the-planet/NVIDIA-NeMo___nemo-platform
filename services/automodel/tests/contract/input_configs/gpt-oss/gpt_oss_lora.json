{
  "seed": 1111,
  "backend": "automodel",
  "model": {
    "name": "openai/gpt-oss-20b",
    "path": "openai/gpt-oss-20b",
    "max_seq_length": 2048
  },
  "dataset": {
    "path": "./sample-datasets/prompt_completion"
  },
  "training": {
    "training_type": "sft",
    "finetuning_type": "lora",
    "lora": {
      "rank": 16,
      "alpha": 32
    }
  },
  "schedule": {
    "epochs": 1,
    "max_steps": 50,
    "val_check_interval": 25
  },
  "batch": {
    "global_batch_size": 8,
    "micro_batch_size": 1,
    "sequence_packing": false
  },
  "optimizer": {
    "learning_rate": 5e-06,
    "weight_decay": 0.01,
    "beta1": 0.9,
    "beta2": 0.999,
    "warmup_steps": 0
  },
  "parallelism": {
    "num_nodes": 1,
    "num_gpus_per_node": 1,
    "tensor_parallel_size": 1,
    "pipeline_parallel_size": 1,
    "context_parallel_size": 1,
    "sequence_parallel": false
  },
  "output_model": "./output_model"
}
