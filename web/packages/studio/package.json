{
  "name": "nemo-studio-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "pnpm concurrently --group -c 'red,blue,green,yellow' -n 'lint:fix,typecheck,test' \"pnpm lint:fix\" \"pnpm typecheck\" \"pnpm test\"",
    "check:ci": "pnpm typecheck",
    "preinstall": "npx only-allow pnpm",
    "start": "vite --mode dev",
    "start:stg": "vite --mode stg",
    "start:dev": "VITE_IS_LOC_ENV='true' vite --mode dev",
    "build": "NODE_ENV=production vite build",
    "build:dev": "tsc && vite build --mode dev",
    "build:fastapi": "pnpm build --mode fastapi",
    "build:fastapi:dev": "export NODE_ENV=fastapi && pnpm build --mode fastapi",
    "dev:preview": "pnpm build:dev && vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix --report-unused-disable-directives --max-warnings 0",
    "lint:a11y": "eslint . --config ../../eslint.config.a11y.js --no-config-lookup --no-inline-config --max-warnings 73",
    "format": "prettier --check './**/*.{js,jsx,ts,tsx}'",
    "format:fix": "prettier --write './**/*.{js,jsx,ts,tsx}'",
    "preview": "vite preview",
    "test": "NODE_OPTIONS=--max-old-space-size=10240 vitest --run",
    "test:coverage": "pnpm test --coverage",
    "test:watch": "NODE_OPTIONS=--max-old-space-size=10240 vitest watch",
    "test:visual": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:local": "MODE='e2e.local' pnpm test:e2e:ui",
    "test:e2e:record": "RECORD=1 playwright test --grep @record",
    "test:ci": "NODE_OPTIONS=--max-old-space-size=10240 CI=true vitest --run --coverage --reporter=junit --reporter=default",
    "typecheck": "tsc --noEmit --noErrorTruncation",
    "typecheck:go": "tsgo --noEmit --noErrorTruncation",
    "bundle-visualize": "pnpm exec vite-bundle-visualizer -c vite.config.ts",
    "update-warning-count": "pnpm tsx ../common/scripts/update-max-warnings.ts",
    "screenshots": "tsx screenshots/capture.ts",
    "feature-flags": "tsx scripts/feature-flag-matrix.ts",
    "fetch-styles": "tsx scripts/fetch-styles.ts"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.28",
    "@hookform/resolvers": "^4.1.3",
    "@mui/x-charts": "catalog:",
    "@mui/x-data-grid": "catalog:",
    "@nemo/common": "workspace:*",
    "@nemo/sdk": "workspace:*",
    "@nvidia/foundations-react-core": "catalog:",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/auto-instrumentations-web": "^0.64.0",
    "@opentelemetry/context-zone": "^2.8.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-trace-web": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-virtual": "^3.13.6",
    "@tanstack/react-query-devtools": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "axios": "catalog:",
    "classnames": "catalog:",
    "handlebars": "catalog:",
    "hyparquet": "catalog:",
    "lucide-react": "catalog:",
    "modern-tour": "^0.1.1",
    "oidc-client-ts": "catalog:",
    "openai": "catalog:",
    "openapi-fetch": "0.9.3",
    "p-limit": "catalog:",
    "papaparse": "^5.5.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-dropzone": "catalog:",
    "react-hook-form": "catalog:",
    "react-oidc-context": "catalog:",
    "react-router": "catalog:",
    "react-router-dom": "catalog:",
    "recharts": "catalog:",
    "seedrandom": "^3.0.5",
    "use-debounce": "catalog:",
    "vite": "catalog:",
    "vite-plugin-mkcert": "catalog:",
    "vitest": "catalog:",
    "yaml": "^2.8.3",
    "zod": "catalog:",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@nemo/testing": "workspace:*",
    "@huggingface/hub": "^1.0.0",
    "@nvidia/foundations-tailwind-plugin": "catalog:",
    "@playwright/test": "^1.57.0",
    "@storybook/react": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
