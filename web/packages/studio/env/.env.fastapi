# This env file is for building the UI to be served by the FastAPI studio service.
# The STUDIO_UI_ markers are replaced at runtime by the FastAPI service with values
# from the platform configuration.
# ENSURE PARITY WITH services/studio/env_mappings.py
#
# Build with: pnpm build --mode fastapi

VITE_ENV_FILE=".env.fastapi"
VITE_BASE_URL=studio
VITE_APP_ENV=STUDIO_UI_VITE_APP_ENV
VITE_AUTH_AUTHORITY=STUDIO_UI_VITE_AUTH_AUTHORITY
VITE_AUTH_CLIENT_ID=STUDIO_UI_VITE_AUTH_CLIENT_ID
VITE_AUTH_SCOPES=STUDIO_UI_VITE_AUTH_SCOPES
VITE_AUTH_SCOPE_PREFIX=STUDIO_UI_VITE_AUTH_SCOPE_PREFIX
VITE_OTEL_COLLECTOR_URL=STUDIO_UI_VITE_OTEL_COLLECTOR_URL
VITE_OTEL_SERVICE_NAME=STUDIO_UI_VITE_OTEL_SERVICE_NAME
VITE_PLATFORM_BASE_URL=STUDIO_UI_VITE_PLATFORM_BASE_URL
VITE_TELEMETRY_ENABLED=STUDIO_UI_VITE_TELEMETRY_ENABLED

# Feature Flags (VITE_FF_* prefix)
VITE_FF_AGENTS_ENABLED=STUDIO_UI_VITE_FF_AGENTS_ENABLED
VITE_FF_CODING_AGENT_STUDIO_ENABLED=STUDIO_UI_VITE_FF_CODING_AGENT_STUDIO_ENABLED
VITE_FF_CUSTOMIZER_ENABLED=STUDIO_UI_VITE_FF_CUSTOMIZER_ENABLED
VITE_FF_DASHBOARD_ENABLED=STUDIO_UI_VITE_FF_DASHBOARD_ENABLED
VITE_FF_DATA_DESIGNER_ENABLED=STUDIO_UI_VITE_FF_DATA_DESIGNER_ENABLED
VITE_FF_DEPLOYMENTS_ENABLED=STUDIO_UI_VITE_FF_DEPLOYMENTS_ENABLED
VITE_FF_EVALUATOR_BENCHMARKS_ENABLED=STUDIO_UI_VITE_FF_EVALUATOR_BENCHMARKS_ENABLED
VITE_FF_EVALUATOR_ENABLED=STUDIO_UI_VITE_FF_EVALUATOR_ENABLED
VITE_FF_EXPERIMENT=STUDIO_UI_VITE_FF_EXPERIMENT
VITE_FF_FILESET_DETAILS_ENABLED=STUDIO_UI_VITE_FF_FILESET_DETAILS_ENABLED
VITE_FF_INFERENCE_PROVIDER_ENABLED=STUDIO_UI_VITE_FF_INFERENCE_PROVIDER_ENABLED
VITE_FF_INTAKE_ENABLED=STUDIO_UI_VITE_FF_INTAKE_ENABLED
VITE_FF_MEMBERS_ENABLED=STUDIO_UI_VITE_FF_MEMBERS_ENABLED
VITE_FF_MODEL_COMPARE_ENABLED=STUDIO_UI_VITE_FF_MODEL_COMPARE_ENABLED
VITE_FF_SAFE_SYNTHESIZER_ENABLED=STUDIO_UI_VITE_FF_SAFE_SYNTHESIZER_ENABLED
VITE_FF_SECRETS_ENABLED=STUDIO_UI_VITE_FF_SECRETS_ENABLED
