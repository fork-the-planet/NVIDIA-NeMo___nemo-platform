# Copy this to `env/.env.dev.local` to use it for local development
# Dev server bind host (Vite `server.host`). Defaults to localhost if unset.
VITE_DEV_SERVER_HOST="localhost"
VITE_IS_LOC_ENV='true'
VITE_OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318/v1/traces"
VITE_OTEL_SERVICE_NAME="nemo-studio-ui"
VITE_PLATFORM_BASE_URL='http://localhost:8080'
VITE_TELEMETRY_ENABLED="false"
VITE_AUTH_CLIENT_ID="<your-client-id>"
VITE_AUTH_AUTHORITY="https://login.microsoftonline.com/<your-tenant-id>/v2.0"
VITE_AUTH_SCOPES="platform:read platform:write openid profile email offline_access"
VITE_AUTH_SCOPE_PREFIX="api://<your-client-id>"

# Feature Flags (VITE_FF_* prefix)
# See src/constants/featureFlags.ts for available flags and documentation.
VITE_FF_AGENTS_ENABLED='true'
VITE_FF_BASE_MODELS_ENABLED='true'
VITE_FF_CODING_AGENT_STUDIO_ENABLED='false'
VITE_FF_CUSTOMIZER_ENABLED='false'
VITE_FF_DASHBOARD_ENABLED='false'
VITE_FF_DATA_DESIGNER_ENABLED='false'
VITE_FF_DATASETS_ENABLED='true'
VITE_FF_DEPLOYMENTS_ENABLED='false'
VITE_FF_EVALUATOR_BENCHMARKS_ENABLED='false'
VITE_FF_EVALUATOR_ENABLED='true'
VITE_FF_EXPERIMENT='true'
VITE_FF_FILESET_DETAILS_ENABLED='false'
VITE_FF_GUARDRAILS_ENABLED='false'
VITE_FF_INFERENCE_PROVIDER_ENABLED='false'
VITE_FF_INTAKE_ENABLED='true'
VITE_FF_JOBS_ENABLED='true'
VITE_FF_MEMBERS_ENABLED='preview'
VITE_FF_MODEL_COMPARE_ENABLED='true'
VITE_FF_SAFE_SYNTHESIZER_ENABLED='false'
VITE_FF_SECRETS_ENABLED='true'
VITE_FF_SETTINGS_ENABLED='true'
