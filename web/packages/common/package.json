{
  "name": "@nemo/common",
  "description": "A package for common code between Studio service and Studio UI. Distributes TS code that is expected to be transpiled by a downstream application.",
  "type": "module",
  "private": "true",
  "scripts": {
    "check": "pnpm concurrently --group -c 'red,blue,green' -n 'typecheck,test,lint:fix' \"pnpm typecheck\" \"pnpm test\" \"pnpm lint:fix\"",
    "check:ci": "pnpm concurrently --group -c 'red,blue' -n 'typecheck,test:ci' \"pnpm typecheck\" \"pnpm test:ci\"",
    "format": "prettier --check './**/*.{js,jsx,ts,tsx}'",
    "format:fix": "prettier --write './**/*.{js,jsx,ts,tsx}'",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix --report-unused-disable-directives --max-warnings 0",
    "test": "vitest --run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:once": "vitest --run",
    "typecheck": "tsc --noEmit",
    "typecheck:go": "tsgo --noEmit"
  },
  "peerDependencies": {
    "@nemo/sdk": "workspace:*",
    "@nvidia/foundations-react-core": "catalog:",
    "@tanstack/react-query": "catalog:",
    "axios": "catalog:",
    "classnames": "catalog:",
    "handlebars": "catalog:",
    "lucide-react": "catalog:",
    "openai": "catalog:",
    "openapi-fetch": "^0.13.3",
    "p-limit": "catalog:",
    "papaparse": "^5.5.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-oidc-context": "catalog:",
    "react-router": "catalog:",
    "react-router-dom": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nemo/testing": "workspace:*",
    "@storybook/react": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/codemirror": "^5.60.16",
    "@types/papaparse": "^5.3.16",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "happy-dom": "catalog:",
    "msw": "catalog:",
    "p-limit": "catalog:",
    "react-hook-form": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-svgr": "catalog:",
    "vitest": "catalog:",
    "vitest-fail-on-console": "catalog:",
    "zod": "catalog:"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.28",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.11.3",
    "@codemirror/lint": "^6.9.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.39.4",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-table": "8.20.5",
    "@tanstack/react-virtual": "3.13.6",
    "@uiw/codemirror-theme-github": "^4.25.2",
    "@uiw/react-codemirror": "^4.25.4",
    "ajv": "^8.18.0",
    "date-fns": "catalog:",
    "html-entities": "^2.5.2",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "unique-names-generator": "^4.7.1",
    "use-debounce": "catalog:",
    "yaml": "^2.8.3"
  }
}
