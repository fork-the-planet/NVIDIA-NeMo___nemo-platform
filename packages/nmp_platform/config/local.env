# Environment variables for local development — no external dependencies.
#
# Entity store uses SQLite below. No PostgreSQL, OpenBao, or other services required.
#
# Usage (from repo root):
#   set -a && source packages/nmp_platform/config/local.env && set +a
#   uv run nemo services run --host 127.0.0.1 --port 8080
#
# CLI against a remote platform (no local nemo services run):
#   export NMP_BASE_URL=http://127.0.0.1:8080
#   nemo auth login --unsigned-token --email you@example.com
#
# Reset local DB + files: stop the platform, then rm -rf ~/.local/share/nemo

# Platform API for `nemo` CLI (overrides ~/.config/nmp/config.yaml when this file is sourced)
NMP_BASE_URL=http://127.0.0.1:8080
NEMO_BASE_URL=http://127.0.0.1:8080

# Config file
NMP_CONFIG_FILE_PATH=packages/nmp_platform/config/local.yaml

# Entity store (SQLite; parent dir is created on first platform start)
DATABASE_DIALECT=sqlite
DATABASE_PATH="${HOME}/.local/share/nemo/nmp-platform.db"

# Docker configuration for jobs (connect to host Docker socket directly)
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_TLS_VERIFY=
DOCKER_API_VERSION=1.50

# Image configuration (use host Docker images directly)
NMP_IMAGE_REGISTRY=my-registry
NMP_IMAGE_TAG=local
NEMO_JOBS_IMAGE_REGISTRY=

# Debug mode
DEBUG=true

# Nemo Safe Synthesizer - disable auto-logging initialization
NSS_DISABLE_AUTO_LOGGING=1

# Docker backend networking configuration
# Mode: 'local' (port forwarding to localhost), 'dond' (container names), 'dind' (port forwarding to docker service)
MODELS_DOCKER_NETWORKING_MODE=local
MODELS_DOCKER_PORT_RANGE_START=8500
MODELS_DOCKER_PORT_RANGE_END=9000
